# ── LLM (Google Gemini via OpenAI-compatible endpoint) ───────────
GEMINI_API_KEY=your_gemini_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.0-flash

# Or use Fireworks AI with DeepSeek (like the demonstrator)
# GEMINI_API_KEY=your_fireworks_key
# LLM_BASE_URL=https://api.fireworks.ai/inference/v1
# LLM_MODEL=accounts/fireworks/models/deepseek-v4-pro

# ── ClickHouse ────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=carouselflow

# ── Datadog ───────────────────────────────────────────────────────
DD_API_KEY=
DD_APP_KEY=
DD_SERVICE=carouselflow-ai
DD_ENV=development
DATADOG_AGENT_HOST=localhost

# ── Server ────────────────────────────────────────────────────────
PORT=3001
DEMO_MODE=true
